<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RACCS - Bluefields | Caribe Sur de Nicaragua</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
font-family:'Segoe UI',sans-serif;
}

body{
background:#021b1a;
color:white;
overflow-x:hidden;
}

/* NAVBAR */

nav{
position:fixed;
top:0;
width:100%;
padding:18px;
background:rgba(0,0,0,.45);
backdrop-filter:blur(10px);
z-index:1000;
}

nav ul{
display:flex;
justify-content:center;
gap:30px;
list-style:none;
}

nav a{
color:white;
text-decoration:none;
font-weight:bold;
transition:.4s;
}

nav a:hover{
color:#80ffdb;
}

/* HERO */

header{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.55),rgba(0,0,0,.75)),
url('https://upload.wikimedia.org/wikipedia/commons/2/2f/Bluefields_Nicaragua.jpg');
background-size:cover;
background-position:center;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
}

.hero{
animation:fadeIn 2s ease;
}

.hero h1{
font-size:5rem;
text-shadow:0 0 20px black;
}

.hero p{
margin-top:20px;
font-size:1.3rem;
max-width:850px;
line-height:1.8;
}

.btn{
display:inline-block;
margin-top:30px;
padding:15px 35px;
background:#006d77;
border-radius:40px;
text-decoration:none;
color:white;
font-weight:bold;
transition:.4s;
}

.btn:hover{
background:#00b4d8;
transform:scale(1.08);
box-shadow:0 0 20px #00b4d8;
}

/* SECTIONS */

section{
padding:100px 10%;
}

.title{
text-align:center;
font-size:3rem;
margin-bottom:50px;
color:#80ffdb;
}

/* INFO */

.info{
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
align-items:center;
}

.info img{
width:100%;
border-radius:20px;
transition:.5s;
}

.info img:hover{
transform:scale(1.03);
}

/* CARDS */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.card{
background:#003845;
border-radius:20px;
overflow:hidden;
transition:.5s;
box-shadow:0 0 15px rgba(0,0,0,.5);
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 25px #00b4d8;
}

.card img{
width:100%;
height:220px;
object-fit:cover;
}

.card-content{
padding:20px;
}

.card h3{
margin-bottom:15px;
color:#caf0f8;
}

/* GALLERY */

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:250px;
object-fit:cover;
border-radius:20px;
transition:.5s;
cursor:pointer;
}

.gallery img:hover{
transform:scale(1.05);
box-shadow:0 0 25px #00b4d8;
}

/* VIDEO */

iframe{
width:100%;
height:500px;
border:none;
border-radius:20px;
}

/* TOURISM BUTTONS */

.tourism-buttons{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:40px;
}

.tourism-buttons a{
text-decoration:none;
background:#006d77;
padding:20px;
border-radius:20px;
text-align:center;
color:white;
font-weight:bold;
transition:.4s;
}

.tourism-buttons a:hover{
background:#00b4d8;
transform:translateY(-5px);
box-shadow:0 0 20px #00b4d8;
}

/* FOOTER */

footer{
background:black;
text-align:center;
padding:40px;
margin-top:50px;
}

/* TOP BUTTON */

#topBtn{
position:fixed;
bottom:30px;
right:30px;
padding:15px 20px;
border:none;
border-radius:50%;
background:#006d77;
color:white;
font-size:18px;
cursor:pointer;
display:none;
transition:.4s;
}

#topBtn:hover{
background:#00b4d8;
transform:scale(1.1);
}

/* DARK MODE */

.toggle{
position:fixed;
left:20px;
bottom:20px;
padding:15px;
border:none;
border-radius:50px;
background:#00b4d8;
cursor:pointer;
font-weight:bold;
z-index:1000;
}

.dark-mode{
background:#f4f4f4;
color:black;
}

/* ANIMATIONS */

.reveal{
opacity:0;
transform:translateY(50px);
transition:1s;
}

.reveal.active{
opacity:1;
transform:translateY(0);
}

@keyframes fadeIn{
from{
opacity:0;
transform:translateY(50px);
}
to{
opacity:1;
transform:translateY(0);
}
}

/* RESPONSIVE */

@media(max-width:900px){

.hero h1{
font-size:3rem;
}

.info{
grid-template-columns:1fr;
}

nav ul{
gap:15px;
font-size:14px;
}

}

</style>
</head>

<body>

<nav>
<ul>
<li><a href="#historia">Historia</a></li>
<li><a href="#cultura">Cultura</a></li>
